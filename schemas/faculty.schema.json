{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-landscape.org/schemas/faculty.schema.json",
  "title": "Faculty frontmatter",
  "allOf": [{ "$ref": "common.schema.json" }, { "properties": { "entity_type": { "const": "faculty" }, "university_id": { "$ref": "common.schema.json#/$defs/id" }, "website": { "type": "string", "format": "uri" } }, "required": ["entity_type", "university_id"] }],
  "unevaluatedProperties": false
}
